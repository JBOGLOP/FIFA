# Entornos
.venv/
venv/
env/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# Datos (no versionar datasets pesados; conservar la estructura con .gitkeep)
data/raw/*
data/interim/*
data/processed/*
data/external/*
