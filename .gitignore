archive/

# El dashboard SÍ se versiona (lo sirve GitHub Pages), incluido su JSON de datos
!docs/data/*.json

# Salidas
outputs/figures/*
outputs/reports/*
outputs/simulations/*
!outputs/**/.gitkeep

# Credenciales
.env
kaggle.json
access_token

# IDE
.vscode/
.idea/

# Config local del agente
.claude/

# Punteros de archivos de Google Drive (no tienen contenido local indexable)
*.gsheet
*.gdoc
*.gslides
*.gdraw
*.glink

archive.zip
